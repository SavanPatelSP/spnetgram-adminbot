# Required
BOT_TOKEN=your_telegram_bot_token_here
JWT_SECRET=your_jwt_secret_here_change_in_production

# Database
DATABASE_URL=postgresql://spnetgram:changeme@localhost:5432/spnetgram

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
HOST=0.0.0.0

# JWT
JWT_EXPIRES_IN=15m

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Postgres (only used by docker-compose)
POSTGRES_PASSWORD=changeme
